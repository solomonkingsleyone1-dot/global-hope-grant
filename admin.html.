<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Dashboard | Global Hope Grant</title>
<link rel="stylesheet" href="style.css">

<style>
body{
    margin:0;
    font-family:Arial,sans-serif;
    background:#f4f4f4;
}

header{
    background:#003c88;
    color:#fff;
    padding:20px;
    text-align:center;
}

.container{
    width:95%;
    max-width:1000px;
    margin:30px auto;
}

.card{
    background:#fff;
    border-radius:10px;
    padding:20px;
    margin-bottom:20px;
    box-shadow:0 2px 10px rgba(0,0,0,.15);
}

h2{
    text-align:center;
}

p{
    margin:8px 0;
}

button{
    background:#003c88;
    color:white;
    border:none;
    padding:10px 18px;
    border-radius:5px;
    cursor:pointer;
    margin-top:15px;
}

button:hover{
    background:#0056c7;
}
</style>

</head>

<body>

<header>
<h1>Global Hope Grant</h1>
<h3>Administrator Dashboard</h3>
</header>

<div class="container">

<h2>Submitted Grant Applications</h2>

<div id="applications">
Loading applications...
</div>

</div>

<script type="module">

import { initializeApp } from "https://www.gstatic.com/firebasejs/12.16.0/firebase-app.js";

import {
getFirestore,
collection,
getDocs
} from "https://www.gstatic.com/firebasejs/12.16.0/firebase-firestore.js";

const firebaseConfig = {

apiKey: "AIzaSyAi1Pbe-HDAsyEYnOyYzgb3HugKQt-4rv8",

authDomain: "global-hope-grant.firebaseapp.com",

projectId: "global-hope-grant",

storageBucket: "global-hope-grant.firebasestorage.app",

messagingSenderId: "253915548678",

appId: "1:253915548678:web:dff5dd9fcd0a9ab821c787"

};

const app = initializeApp(firebaseConfig);

const db = getFirestore(app);

const applicationsDiv = document.getElementById("applications");

applicationsDiv.innerHTML = "";

async function loadApplications(){

const querySnapshot = await getDocs(collection(db,"applications"));

if(querySnapshot.empty){

applicationsDiv.innerHTML="<h3>No grant applications found.</h3>";

return;

}

querySnapshot.forEach((doc)=>{

const data=doc.data();

applicationsDiv.innerHTML += `

<div class="card">

<h3>${data.fullname}</h3>

<p><strong>Email:</strong> ${data.email}</p>

<p><strong>Phone:</strong> ${data.phone}</p>

<p><strong>Country:</strong> ${data.country}</p>

<p><strong>Grant Type:</strong> ${data.grantType}</p>

<p><strong>Amount Requested:</strong> $${data.amount}</p>

<p><strong>Reason:</strong><br>${data.reason}</p>

<p><strong>Date Submitted:</strong> ${data.date}</p>

</div>

`;

});

}

loadApplications();

</script>

</body>
</html>
